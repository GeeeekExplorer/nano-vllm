-height: 1.4; word-break: break-all;&quot;&gt;postprocess&lt;/code&gt;，直到无等待/运行序列。&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr class=&quot;border-border border-b&quot; data-streamdown=&quot;table-row&quot; style=&quot;border: none !important;&quot;&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: 1px solid color(srgb 1 1 1 / 0.08); border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;Scheduler&lt;/span&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: none; border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;维护&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;waiting&lt;/code&gt;/&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;running&lt;/code&gt;；prefill 时&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;allocate&lt;/code&gt;&lt;/span&gt;；decode 时&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;may_append&lt;/code&gt;&lt;/span&gt;；结束或抢占时&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;deallocate&lt;/code&gt;&lt;/span&gt;。&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr class=&quot;border-border border-b&quot; data-streamdown=&quot;table-row&quot; style=&quot;border: none !important;&quot;&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: 1px solid color(srgb 1 1 1 / 0.08); border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;Sequence&lt;/span&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: none; border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;存&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;语义 token 序列&lt;/span&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;+&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;block_table&lt;/code&gt;（逻辑→物理 KV 块）&lt;/span&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;+&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;num_cached_tokens&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;/&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;num_scheduled_tokens&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;等，给调度和&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;ModelRunner&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;共用。&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr class=&quot;border-border border-b&quot; data-streamdown=&quot;table-row&quot; style=&quot;border: none !important;&quot;&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: 1px solid color(srgb 1 1 1 / 0.08); border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;Block / BlockManager&lt;/span&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: none; border-bottom: 1px solid color(srgb 1 1 1 / 0.08);&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;管&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;全局 KV 块池&lt;/span&gt;与引用计数；&lt;code class=&quot;md-inline-path-filename-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-prefix&quot;&gt;allocate/may_append/&lt;/span&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;deallocate&lt;/span&gt;&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;与&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-path-filename-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;seq.block_table&lt;/span&gt;&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;同步。&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr class=&quot;border-border border-b&quot; data-streamdown=&quot;table-row&quot; style=&quot;border: none !important;&quot;&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: 1px solid color(srgb 1 1 1 / 0.08); border-bottom: none;&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;ModelRunner&lt;/span&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style=&quot;padding: 5px 9px; text-align: left; vertical-align: top; border-right: none; border-bottom: none;&quot;&gt;&lt;div class=&quot;md-table-cell-content&quot; style=&quot;display: block; min-inline-size: 6ch; max-inline-size: 280.312px; white-space: normal; overflow-wrap: break-word; word-break: normal;&quot;&gt;&lt;span class=&quot;font-semibold&quot; data-streamdown=&quot;strong&quot; style=&quot;--tw-font-weight: 600; font-weight: 600;&quot;&gt;只读&lt;/span&gt;调度好的&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;Sequence&lt;/code&gt;，把&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;block_table&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;变成 GPU 上的&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;slot_mapping&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;/&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-variable-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;block_tables&lt;/code&gt;，做 forward 和采样。&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" id="q8GB3TMjlZwETCwJwJUX-6">
