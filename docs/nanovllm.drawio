&lt;div class=&quot;ui-default-code__line&quot; style=&quot;display: flex; min-height: 20px; color: rgb(255, 255, 255); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(36, 37, 41); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;div class=&quot;ui-default-code__line-content&quot; style=&quot;flex: 1 1 0%; white-space: pre; overflow: hidden; text-overflow: ellipsis; padding-left: 6px; color: rgb(255, 255, 255); padding-right: 8px; position: relative;&quot;&gt;&lt;span&gt;并通过 hash 做 prefix cache 复用。&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
