        <UserObject label="&lt;ul class=&quot;list-inside list-disc whitespace-normal [li_&amp;amp;]:pl-6&quot; data-streamdown=&quot;unordered-list&quot; style=&quot;--tw-space-y-reverse: 0; margin-block: 0px 16px; list-style-type: disc; white-space: normal; padding-left: 2em; display: flex !important; flex-direction: column !important; gap: 6px !important; margin: 6px 0px !important; color: rgb(255, 255, 255); font-family: &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 13px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; background-color: rgb(36, 37, 41); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;构建&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;Config&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;设置&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-path-filename-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;Sequence.block_size&lt;/span&gt;&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;启动 TP 子进程（rank 1..N-1）&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;在 rank0 创建本地&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;ModelRunner&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;初始化 tokenizer，设置&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-path-filename-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;config.eos&lt;/span&gt;&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;创建&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; f