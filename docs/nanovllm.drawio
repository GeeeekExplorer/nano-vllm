er New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;Sequence.block_size&lt;/span&gt;&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;启动 TP 子进程（rank 1..N-1）&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;在 rank0 创建本地&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;ModelRunner&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;初始化 tokenizer，设置&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;md-inline-path-filename-like&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;&lt;span class=&quot;md-inline-path-filename&quot;&gt;config.eos&lt;/span&gt;&lt;/code&gt;&lt;/li&gt;&lt;li class=&quot;py-1 [&amp;amp;&amp;gt;p]:inline&quot; data-streamdown=&quot;list-item&quot; style=&quot;padding-block: 4px; word-break: break-word; padding: 0px !important;&quot;&gt;创建&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;Scheduler&lt;/code&gt;&lt;/li&gt;&lt;/ul&gt;" id="jlL7_1UDXELywasUuRNv-8">
