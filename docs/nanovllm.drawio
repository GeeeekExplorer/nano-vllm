<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6" pages="5">
  <diagram name="时序图" id="PGjhzMVYIUYz58zE8h2v">
    <mxGraphModel dx="4570" dy="2434" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {&#39;theme&#39;: &#39;base&#39;, &#39;themeVariables&#39;: {\n  &#39;primaryColor&#39;: &#39;#E8F4FF&#39;,\n  &#39;primaryBorderColor&#39;: &#39;#2563EB&#39;,\n  &#39;primaryTextColor&#39;: &#39;#0F172A&#39;,\n  &#39;lineColor&#39;: &#39;#334155&#39;,\n  &#39;signalColor&#39;: &#39;#1D4ED8&#39;,\n  &#39;signalTextColor&#39;: &#39;#0F172A&#39;,\n  &#39;noteBkgColor&#39;: &#39;#FEF3C7&#39;,\n  &#39;noteBorderColor&#39;: &#39;#D97706&#39;,\n  &#39;actorBkg&#39;: &#39;#FDF2F8&#39;,\n  &#39;actorBorder&#39;: &#39;#BE185D&#39;,\n  &#39;activationBkgColor&#39;: &#39;#DBEAFE&#39;,\n  &#39;activationBorderColor&#39;: &#39;#1D4ED8&#39;\n}}}%%\nsequenceDiagram\nautonumber\nactor U as 用户\nparticipant EX as example.py\nparticipant ENG as LLMEngine\nparticipant SCH as Scheduler\nparticipant MR0 as ModelRunner-r0\nparticipant MR1 as ModelRunner-r1\nparticipant SHM as SharedMemory+Event\nparticipant MOD as Qwen3(张量并行)\nparticipant SMP as Sampler\n\nrect rgba(220,255,220,0.35)\nU-&gt;&gt;EX: 运行脚本\nEX-&gt;&gt;ENG: LLM(path, enforce_eager=True, tp=2)\nend\n\npar 初始化rank0\n  rect rgba(219,234,254,0.45)\n  ENG-&gt;&gt;MR0: 构建ModelRunner(rank0)\n  MR0-&gt;&gt;MOD: 加载权重 + warmup + 分配KV Cache\n  MR0-&gt;&gt;SHM: create(\&quot;nanovllm\&quot;)\n  end\nand 初始化rank1\n  rect rgba(255,235,205,0.45)\n  ENG-&gt;&gt;MR1: spawn子进程并构建ModelRunner(rank1)\n  MR1-&gt;&gt;MOD: 加载权重 + warmup + 分配KV Cache\n  MR1-&gt;&gt;SHM: attach(\&quot;nanovllm\&quot;) 后进入 loop 等待\n  end\nend\n\nrect rgba(220,235,255,0.35)\nEX-&gt;&gt;ENG: generate(prompts, sampling_params)\nend\n\nloop 直到所有序列完成\n  ENG-&gt;&gt;SCH: schedule()\n  alt Prefill\n    SCH--&gt;&gt;ENG: (seqs, is_prefill=True)\n  else Decode\n    SCH--&gt;&gt;ENG: (seqs, is_prefill=False)\n  end\n\n  rect rgba(224,255,255,0.45)\n  ENG-&gt;&gt;MR0: call(\&quot;run\&quot;, seqs, is_prefill)\n  MR0-&gt;&gt;SHM: 写入method+args并event.set()\n  SHM--&gt;&gt;MR1: 唤醒worker执行同一run\n  end\n\n  MR0-&gt;&gt;MOD: 前向计算(logits)\n  MR1-&gt;&gt;MOD: 前向计算(参与TP通信)\n  Note over MR0: enforce_eager=True\\nprefill/decode都走eager\n  MR0-&gt;&gt;SMP: 采样token_ids(仅rank0)\n  MR0--&gt;&gt;ENG: 返回token_ids\n  ENG-&gt;&gt;SCH: postprocess(append_token/结束判定/释放block)\nend\n\nENG--&gt;&gt;EX: outputs(text + token_ids)\n\nrect rgba(255,228,225,0.45)\nEX-&gt;&gt;ENG: 进程退出(atexit)\nENG-&gt;&gt;MR0: call(\&quot;exit\&quot;)\nMR0-&gt;&gt;SHM: 广播exit给worker\npar rank0清理\n  MR0-&gt;&gt;SHM: close + unlink\nand rank1清理\n  MR1-&gt;&gt;SHM: close\nend\nend&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="KP6RIerTd-46lAfgn8-y-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2273" width="2448" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
