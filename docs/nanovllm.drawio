: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;seqs&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;是本轮要送进模型执行的&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code class=&quot;&quot; style=&quot;padding: 1.5px 4px; border-radius: 5px; background-color: color(srgb 1 1 1 / 0.08); color: color(srgb 1 1 1 / 0.94); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.9em; line-height: 1.4; word-break: break-all;&quot;&gt;Sequence&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;列表。&lt;/p&gt;&lt;p style=&quot;--tw-space-y-reverse: 0; margin-block: 0px 16px; margin: 6px 0px; word-break: break-word; color: rgb(255, 255, 255); font-family: &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 13px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(36, 37, 41); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;可能来自：&lt;/p&gt;&lt;ul class=&quot;list-inside list-disc whitespace-normal [li_&amp;amp;]:pl-6&quot; data-streamdown=&quot;unordered-list&quot; style=&quot;--tw-space-y-reverse: 0; margin-block: 0px 16px; list-style-type: disc; white-space: normal; padding-left: 2em; display: flex !important; flex-direction: column !important; gap: 6px !important; margin: 6px 0px !important; color: rgb(255, 255, 255); font-family: &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 13px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-indent: 0px; text-transform: none; widows: 2; word-spacin