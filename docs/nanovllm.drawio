        <mxCell id="E9PR5LhrZ70zgyE1gl5S-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;pre class=&quot;syl-page-code&quot; style=&quot;box-sizing: border-box; font-family: Monaco; font-size: 18px; margin: 20px 0px; padding: 15px; border: 0px; background: rgb(250, 250, 250); white-space: pre-wrap; word-break: break-all; display: block; overflow-x: auto; border-radius: 3px; text-align: left; color: rgb(34, 34, 34); box-shadow: rgba(216, 216, 216, 0.5) 0px 0px 0px 1px inset; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code class=&quot;hljs less&quot; style=&quot;box-sizing: border-box; font-family: inherit; font-size: 14px; margin: 0px; padding: 0px; border: 0px; overflow-wrap: normal; word-break: normal; overflow-x: auto; line-height: 24px; white-space: pre !important;&quot;&gt;用户调用 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;generate&lt;/span&gt;(): llm.generate([&quot;Hello world&quot;], sampling_params)&lt;br&gt;  → &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;LLMEngine&lt;/span&gt;&lt;span class=&quot;hljs-selector-class&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;.add_request&lt;/span&gt;() &amp;nbsp;  将文本转为 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Sequence&lt;/span&gt; 对象，进入 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Waiting&lt;/span&gt; 队列&lt;br&gt;  → 进入 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;step&lt;/span&gt; &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;loop&lt;/span&gt;（每次调用 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;step&lt;/span&gt;() 方法）&lt;br&gt; &amp;nbsp;  → &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Scheduler&lt;/span&gt;&lt;span class=&quot;hljs-selector-class&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;.schedule&lt;/span&gt;() &amp;nbsp; &amp;nbsp; 决定这一步处理哪些序列，是 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;prefill&lt;/span&gt; 还是 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;decode&lt;/span&gt;&lt;br&gt; &amp;nbsp;  → &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;ModelRunner&lt;/span&gt;&lt;span class=&quot;hljs-selector-class&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;.call&lt;/span&gt;(&lt;span class=&quot;hljs-string&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(0, 117, 59);&quot;&gt;&quot;run&quot;&lt;/span&gt;)  在 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;GPU&lt;/span&gt; 上执行前向计算并采样&lt;br&gt; &amp;nbsp;  → &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Scheduler&lt;/span&gt;&lt;span class=&quot;hljs-selector-class&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;.postprocess&lt;/span&gt;()  将新 &lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;token&lt;/span&gt; 加入序列，检测是否完成&lt;br&gt;  → 所有请求完成，&lt;span class=&quot;hljs-selector-tag&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;tokenizer&lt;/span&gt;&lt;span class=&quot;hljs-selector-class&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;.decode&lt;/span&gt;() 转回文本返回&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="230" width="540" x="10" y="790" as="geometry" />
        </mxCell>
        <mxCell id="IGJKPEuWQs6qO7eG-Psd-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p style=&quot;box-sizing: border-box; margin: 20px 0px; padding: 0px; border: 0px; color: rgb(34, 34, 34); font-family: &amp;quot;PingFang SC&amp;quot;, &amp;quot;Hiragino Sans GB&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, Arial, sans-serif; font-size: 18px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: justify; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; line-height: 1.75;&quot;&gt;Scheduler 维护两个队列：&lt;/p&gt;&lt;ul style=&quot;box-sizing: border-box; margin: 20px 30px; padding: 0px; border: 0px; counter-reset: ul_list 0; color: rgb(34, 34, 34); font-family: &amp;quot;PingFang SC&amp;quot;, &amp;quot;Hiragino Sans GB&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, Arial, sans-serif; font-size: 18px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: justify; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; list-style: none; border: 0px;&quot;&gt;&lt;strong style=&quot;box-sizing: border-box; font-weight: 700; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Waiting Queue&lt;/strong&gt;：已提交但尚未开始处理的序列（等待 prefill）&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; list-style: none; border: 0px;&quot;&gt;&lt;strong style=&quot;box-sizing: border-box; font-weight: 700; margin: 0px; padding: 0px; border: 0px;&quot;&gt;Running Queue&lt;/strong&gt;：正在处理中的序列（decode 阶段）&lt;/li&gt;&lt;/ul&gt;&lt;p style=&quot;box-sizing: border-box; margin: 20px 0px; padding: 0px; border: 0px; color: rgb(34, 34, 34); font-family: &amp;quot;PingFang SC&amp;quot;, &amp;quot;Hiragino Sans GB&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, Arial, sans-serif; font-size: 18px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: justify; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; line-height: 1.75;&quot;&gt;schedule() 方法在每个 step 被调用，返回两个东西：这一步要处理的序列批次（batch），以及执行动作（prefill 还是 decode）。&lt;/p&gt;" vertex="1">
          <mxGeometry height="220" width="560" x="250" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="IGJKPEuWQs6qO7eG-Psd-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;pre class=&quot;syl-page-code&quot; style=&quot;box-sizing: border-box; font-family: Monaco; font-size: 18px; margin: 20px 0px; padding: 15px; border: 0px; background: rgb(250, 250, 250); white-space: pre-wrap; word-break: break-all; display: block; overflow-x: auto; border-radius: 3px; text-align: left; color: rgb(34, 34, 34); box-shadow: rgba(216, 216, 216, 0.5) 0px 0px 0px 1px inset; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code class=&quot;hljs sql&quot; style=&quot;box-sizing: border-box; font-family: inherit; font-size: 14px; margin: 0px; padding: 0px; border: 0px; overflow-wrap: normal; word-break: normal; overflow-x: auto; line-height: 24px; white-space: pre !important;&quot;&gt;schedule() 被调用的决策流程&lt;br&gt;│&lt;br&gt;├─ 【优先】遍历 Waiting Queue（Prefill 阶段）&lt;br&gt;│ &amp;nbsp; ├─ 调用 BlockManager.can_allocate(seq)&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; └─ 检查是否有足够的 Block 存放整个 prompt 的 KV &lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;Cache&lt;/span&gt;&lt;br&gt;│ &amp;nbsp; ├─ 如果有空间 → 移入 Running，执行 prefill&lt;br&gt;│ &amp;nbsp; ├─ 如果没空间 → 停止遍历&lt;br&gt;│ &amp;nbsp; └─ 如果有任何序列被调度 → 立即返回 (batch, is_prefill=&lt;span class=&quot;hljs-literal&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(138, 115, 4);&quot;&gt;True&lt;/span&gt;)&lt;br&gt;│&lt;br&gt;├─ 【其次】遍历 Running Queue（&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;Decode&lt;/span&gt; 阶段）&lt;br&gt;│ &amp;nbsp; ├─ 调用 BlockManager.can_append(seq)&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; └─ 检查是否有空闲 &lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;Block&lt;/span&gt; 存放下一个 token 的 KV &lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;Cache&lt;/span&gt;&lt;br&gt;│ &amp;nbsp; ├─ 如果有空间 → 留在 Running，继续 &lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;decode&lt;/span&gt;&lt;br&gt;│ &amp;nbsp; └─ 如果没空间 → **抢占（Preempt）**，移回 Waiting 队列头部&lt;br&gt;│&lt;br&gt;└─ 返回 (batch, is_prefill=&lt;span class=&quot;hljs-literal&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(138, 115, 4);&quot;&gt;False&lt;/span&gt;)&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="480" width="500" x="1260" y="1657" as="geometry" />
        </mxCell>
        <mxCell id="IGJKPEuWQs6qO7eG-Psd-3" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;strong style=&quot;box-sizing: border-box; font-weight: 700; margin: 0px; padding: 0px; border: 0px; color: rgb(34, 34, 34); font-family: &amp;quot;PingFang SC&amp;quot;, &amp;quot;Hiragino Sans GB&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, Arial, sans-serif; font-size: 18px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: justify; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;重要：实际代码中 Prefill 优先于 Decode&lt;/strong&gt;&lt;span style=&quot;color: rgb(34, 34, 34); font-family: &amp;quot;PingFang SC&amp;quot;, &amp;quot;Hiragino Sans GB&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, Arial, sans-serif; font-size: 18px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: justify; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(255, 255, 255); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;。&lt;/span&gt;" vertex="1">
          <mxGeometry height="33" width="369" x="1309.75" y="2110" as="geometry" />
        </mxCell>
        <mxCell id="IGJKPEuWQs6qO7eG-Psd-5" parent="1" style="text;whiteSpace=wrap;html=1;" value="用空间换时间的同时，又用缓存把时间追回来。" vertex="1">
          <mxGeometry height="40" width="195.75" x="904.25" y="2487" as="geometry" />
        </mxCell>
        <UserObject label="&lt;a href=&quot;https://www.toutiao.com/article/7602678840405574144/&quot;&gt;Nano-vLLM 源码深度解剖：DeepSeek 工程师开源LLM 推理引擎全部秘密 - 今日头条&lt;/a&gt;" link="&lt;a href=&quot;https://www.toutiao.com/article/7602678840405574144/&quot;&gt;Nano-vLLM 源码深度解剖：DeepSeek 工程师开源LLM 推理引擎全部秘密 - 今日头条&lt;/a&gt;" id="IGJKPEuWQs6qO7eG-Psd-6">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="40" width="480" x="490" y="20" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="yf0rFs4f2XjZsz79dRkf-4" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;pre class=&quot;syl-page-code&quot; style=&quot;box-sizing: border-box; font-family: Monaco; font-size: 18px; margin: 20px 0px; padding: 15px; border: 0px; background: rgb(250, 250, 250); white-space: pre-wrap; word-break: break-all; display: block; overflow-x: auto; border-radius: 3px; text-align: left; color: rgb(34, 34, 34); box-shadow: rgba(216, 216, 216, 0.5) 0px 0px 0px 1px inset; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code class=&quot;hljs ruby&quot; style=&quot;box-sizing: border-box; font-family: inherit; font-size: 14px; margin: 0px; padding: 0px; border: 0px; overflow-wrap: normal; word-break: normal; overflow-x: auto; line-height: 24px; white-space: pre !important;&quot;&gt;&lt;span class=&quot;hljs-function&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(138, 115, 4);&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;def&lt;/span&gt; &lt;span class=&quot;hljs-title&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;prepare_prefill&lt;/span&gt;&lt;span class=&quot;hljs-params&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;(&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;self&lt;/span&gt;, sequences)&lt;/span&gt;&lt;/span&gt;:&#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# 多个序列的 prompt 长度不同，需要打包&lt;/span&gt;&#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# 用 cu_seqlens（累积序列长度）告诉 FlashAttention 边界在哪&lt;/span&gt;&#xa;    &#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# 序列 A: 100 tokens, 序列 B: 200 tokens, 序列 C: 150 tokens&lt;/span&gt;&#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → input_ids = [A的100个token, B的200个token, C的150个token]  (共450)&lt;/span&gt;&#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → cu_seqlens = [0, 100, 300, 450]&lt;/span&gt;&#xa;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → slot_mapping = [每个token对应的KV Cache物理位置]&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="290" width="560" x="2690" y="295" as="geometry" />
        </mxCell>
        <mxCell id="yf0rFs4f2XjZsz79dRkf-5" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;pre class=&quot;syl-page-code&quot; style=&quot;box-sizing: border-box; font-family: Monaco; font-size: 18px; margin: 20px 0px; padding: 15px; border: 0px; background: rgb(250, 250, 250); white-space: pre-wrap; word-break: break-all; display: block; overflow-x: auto; border-radius: 3px; text-align: left; color: rgb(34, 34, 34); box-shadow: rgba(216, 216, 216, 0.5) 0px 0px 0px 1px inset; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;code class=&quot;hljs ruby&quot; style=&quot;box-sizing: border-box; font-family: inherit; font-size: 14px; margin: 0px; padding: 0px; border: 0px; overflow-wrap: normal; word-break: normal; overflow-x: auto; line-height: 24px; white-space: pre !important;&quot;&gt;&lt;span class=&quot;hljs-function&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(138, 115, 4);&quot;&gt;&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;def&lt;/span&gt; &lt;span class=&quot;hljs-title&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(168, 46, 46);&quot;&gt;prepare_decode&lt;/span&gt;&lt;span class=&quot;hljs-params&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px;&quot;&gt;(&lt;span class=&quot;hljs-keyword&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(17, 75, 166);&quot;&gt;self&lt;/span&gt;, sequences)&lt;/span&gt;&lt;/span&gt;:&lt;br&gt;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# 每个序列只有 1 个新 token，即 num_scheduled_tokens = 1&lt;br&gt;&lt;/span&gt;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → input_ids = [A的第101个token, B的第201个token, C的第151个token]  (共3)&lt;/span&gt;&lt;br&gt;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → positions = [100, 200, 150]  (每个token的位置)&lt;/span&gt;&lt;br&gt;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → slot_mapping = [3个物理位置]&lt;/span&gt;&lt;br&gt;    &lt;span class=&quot;hljs-comment&quot; style=&quot;box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; color: rgb(153, 153, 153);&quot;&gt;# → block_tables = [[A的Block列表], [B的Block列表], [C的Block列表]]&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="220" width="560" x="2680" y="640" as="geometry" />
        </mxCell>
